{
  "id": "python_action_flow",
  "name": "Python Action Flow",
  "description": "Run a Python action handler loaded from the workflows directory.",
  "entrypoint": "run_action",
  "steps": [
    {
      "id": "run_action",
      "name": "Greet via Python handler",
      "type": "action",
      "handler": "test_actions.greet",
      "handler_input": { "name": "{{ run.user_request }}" },
      "output_key": "greeting"
    },
    {
      "id": "result",
      "name": "Produce Result",
      "type": "result",
      "requires": ["run_action"]
    }
  ]
}
