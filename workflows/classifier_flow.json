{
  "id": "classifier_flow",
  "name": "Classifier Flow",
  "description": "Two MCP fetchers (Jira + GitHub); classifier picks which to run based on the user request; LLM processes the selected context.",
  "entrypoint": "fetch_jira",
  "metadata": {
    "use_classifier": true
  },
  "steps": [
    {
      "id": "fetch_jira",
      "name": "Fetch Jira Issue",
      "type": "fetch",
      "tool": "jira_get_issue",
      "tool_input": { "issue_key": "PROJ-1" },
      "output_key": "jira_context"
    },
    {
      "id": "fetch_github",
      "name": "Fetch GitHub Repo",
      "type": "fetch",
      "tool": "github_get_repo",
      "tool_input": { "repo": "acme/my-service" },
      "output_key": "repo_context"
    },
    {
      "id": "ask_llm",
      "name": "Analyse with LLM",
      "type": "llm",
      "output_key": "agent_result"
    }
  ]
}
